@model IEnumerable<Clinic_System.Models.TipoCita>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create" class="btn-create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.NombreTipoCita)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Precio)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Especialidad)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.NombreTipoCita)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Precio)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Especialidad.NombreEspecialidad)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.IdTipoCita">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.IdTipoCita">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.IdTipoCita">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
