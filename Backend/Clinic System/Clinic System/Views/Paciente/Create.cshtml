@model Clinic_System.Models.Paciente

@{
    ViewData["Title"] = "Create";
}

<h1 class="page-title">Nuevo Paciente</h1>

<div class="card">

<form asp-action="Create">

<div class="form-group">
<label asp-for="Nombre" class="form-label"></label>
<input asp-for="Nombre" class="form-input"/>
<span asp-validation-for="Nombre" class="text-danger"></span>
</div>

<div class="form-group">
<label asp-for="Apellido" class="form-label"></label>
<input asp-for="Apellido" class="form-input"/>
</div>

<div class="form-group">
<label asp-for="DNI" class="form-label"></label>
<input asp-for="DNI" class="form-input"/>
</div>

<div class="form-group">
<label asp-for="FechaNacimiento" class="form-label"></label>
<input asp-for="FechaNacimiento" type="date" class="form-input"/>
</div>

<div class="form-group">
<label asp-for="Correo" class="form-label"></label>
<input asp-for="Correo" class="form-input"/>
</div>

<div class="form-group">
<label asp-for="Telefono" class="form-label"></label>
<input asp-for="Telefono" class="form-input"/>
</div>

<button type="submit" class="btn btn-primary">Guardar Paciente</button>
<a asp-action="Index" class="btn btn-secondary">Cancelar</a>

</form>

</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
