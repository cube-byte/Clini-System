@model Clinic_System.Models.Medico

@{
    ViewData["Title"] = "Create";
}

<h1 class="page-title">Nuevo Médico</h1>

<div class="card">

    <form asp-action="Create" method="post">

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group">
            <label asp-for="Nombre" class="form-label"></label>
            <input asp-for="Nombre" class="form-input" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Apellido" class="form-label"></label>
            <input asp-for="Apellido" class="form-input" />
            <span asp-validation-for="Apellido" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="DNI" class="form-label"></label>
            <input asp-for="DNI" class="form-input" />
            <span asp-validation-for="DNI" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Telefono" class="form-label"></label>
            <input asp-for="Telefono" class="form-input" />
            <span asp-validation-for="Telefono" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Correo" class="form-label"></label>
            <input asp-for="Correo" class="form-input" />
            <span asp-validation-for="Correo" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="IdEspecialidad" class="form-label"></label>
            <select asp-for="IdEspecialidad" class="form-input" asp-items="ViewBag.Especialidad">
                <option value="">Seleccione especialidad</option>
            </select>
            <span asp-validation-for="IdEspecialidad" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Guardar Médico</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>

    </form>

</div>